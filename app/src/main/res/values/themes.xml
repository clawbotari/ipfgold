<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.Ipfgold" parent="android:Theme.Material3.Light.NoActionBar">
        <!-- Customize your theme here. -->
        <item name="colorPrimary">@color/gold_primary</item>
        <item name="colorPrimaryVariant">@color/gold_secondary</item>
        <item name="colorOnPrimary">@color/on_surface</item>
        <item name="colorSecondary">@color/gold_tertiary</item>
        <item name="colorSecondaryVariant">@color/gold_secondary</item>
        <item name="colorOnSecondary">@color/on_surface</item>
        <item name="android:statusBarColor" tools:targetApi="l">?attr/colorPrimaryVariant</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">true</item>
    </style>

    <style name="Theme.Ipfgold.Dark" parent="android:Theme.Material3.Dark.NoActionBar">
        <item name="colorPrimary">@color/gold_primary</item>
        <item name="colorPrimaryVariant">@color/gold_secondary</item>
        <item name="colorOnPrimary">@color/surface</item>
        <item name="colorSecondary">@color/gold_tertiary</item>
        <item name="colorSecondaryVariant">@color/gold_secondary</item>
        <item name="colorOnSecondary">@color/surface</item>
        <item name="android:statusBarColor" tools:targetApi="l">?attr/colorPrimaryVariant</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">false</item>
    </style>
</resources>
